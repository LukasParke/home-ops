---
apiVersion: v1
kind: Secret
metadata:
  name: cluster-secrets
stringData:
  SECRET_DOMAIN: "#{ cloudflare_domain }#"
  CLOUDFLARE_ACCOUNT_ID: "#{ cloudflare_account_tag() }#"
  CLOUDFLARE_TUNNEL_ID: "#{ cloudflare_tunnel_id() }#"
  CLOUDFLARE_TUNNEL_API_TOKEN: "#{ cloudflare_token }#"
  # Shared app credentials (same keys as live cluster-secrets; encrypt with SOPS before apply):
  # RADARR__AUTH__APIKEY
  # SONARR__AUTH__APIKEY
  # LIDARR__AUTH__APIKEY
  # PROWLARR__AUTH__APIKEY
  # Homepage Homelab links/widgets: UNRAID_URL, CLOUDFLARE_ACCOUNT_ID, CLOUDFLARE_TUNNEL_ID,
  #   CLOUDFLARE_TUNNEL_API_TOKEN
  # Homepage Cluster widgets + Ghostfolio app: TAUTULLI_API_KEY, GRAFANA_USERNAME,
  #   GRAFANA_PASSWORD, GHOSTFOLIO_ACCESS_TOKEN_SECRET, GHOSTFOLIO_JWT_SECRET_KEY
  # Forgejo (substitute into HelmRelease): FORGEJO_ADMIN_USERNAME, FORGEJO_ADMIN_PASSWORD, FORGEJO_ADMIN_EMAIL
